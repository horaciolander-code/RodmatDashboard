# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-real-secret
TOKEN_EXPIRE_MINUTES=480

# Database — Railway/Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://api.dashboard.rodmatcenter.com,https://app.dashboard.rodmatcenter.com

# Environment
ENVIRONMENT=prod

# Superadmin & internal key
SUPERADMIN_EMAIL=Rodmatwh@gmail.com
INTERNAL_API_KEY=change-me-generate-a-real-key

# SMTP (Gmail app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=Rodmatwh@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Groq AI (for agents)
GROQ_API_KEY=your-groq-api-key

# Streamlit dashboard URL
API_BASE_URL=https://api.dashboard.rodmatcenter.com/api
